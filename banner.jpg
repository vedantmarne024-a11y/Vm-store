          let cspReportsCount = 0;
          document.addEventListener('securitypolicyviolation', async (event) => {
            if (event.originalPolicy.includes('report-uri') || cspReportsCount >= 500) {
              return;
            }
            cspReportsCount += 1;
            await fetch('/_/_/csp_report/', {
              method: 'POST',
              body: JSON.stringify({
                'csp-report': {
                  'blocked-uri': event.blockedURI,
